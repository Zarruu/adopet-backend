# Server
PORT=8080
GIN_MODE=debug
JWT_SECRET=adopet-secret-key-ganti-di-production-2026

# Auth Database (XAMPP MySQL)
AUTH_DB_HOST=127.0.0.1
AUTH_DB_PORT=3306
AUTH_DB_USER=root
AUTH_DB_PASS=
AUTH_DB_NAME=adopet_auth

# Pets Database (XAMPP MySQL)
PETS_DB_HOST=127.0.0.1
PETS_DB_PORT=3306
PETS_DB_USER=root
PETS_DB_PASS=
PETS_DB_NAME=adopet_pets

# Google Drive (opsional — kosongkan untuk mode local storage)
GDRIVE_CREDENTIALS_JSON=
GDRIVE_FOLDER_ID=

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Default Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@adopet.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
