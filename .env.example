# Server
PORT=8080
GIN_MODE=debug

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database Auth (adopet_auth)
DB_AUTH_HOST=localhost
DB_AUTH_PORT=3306
DB_AUTH_USER=root
DB_AUTH_PASSWORD=
DB_AUTH_NAME=adopet_auth

# Database Pets (adopet_pets)
DB_PETS_HOST=localhost
DB_PETS_PORT=3306
DB_PETS_USER=root
DB_PETS_PASSWORD=
DB_PETS_NAME=adopet_pets

# Google Drive (optional - if not set, will use local file storage)
GDRIVE_CREDENTIALS_JSON=
GDRIVE_FOLDER_ID=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Default Admin (created on first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@adopet.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
